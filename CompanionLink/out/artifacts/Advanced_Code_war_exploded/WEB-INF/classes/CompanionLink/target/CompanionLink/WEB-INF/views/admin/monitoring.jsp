<%@ include file="../partials/header.jspf" %>
<div class="page-title"><h1>Platform Monitoring</h1><a class="btn secondary" href="<%=ctx%>/admin/dashboard">Analytics</a></div>
<div class="card"><h2>Requests</h2><div class="table-wrap"><table><thead><tr><th>ID</th><th>Senior</th><th>Activity</th><th>Date</th><th>Area</th><th>Status</th></tr></thead><tbody><c:forEach var="r" items="${requests}"><tr><td>${r.id}</td><td>${r.seniorName}</td><td>${r.activityName}</td><td>${r.preferredDateTime}</td><td>${r.locationArea}</td><td>${r.status}</td></tr></c:forEach></tbody></table></div></div>
<div class="card"><h2>Visits</h2><div class="table-wrap"><table><thead><tr><th>ID</th><th>Senior</th><th>Volunteer</th><th>Activity</th><th>Scheduled</th><th>Status</th></tr></thead><tbody><c:forEach var="v" items="${visits}"><tr><td>${v.id}</td><td>${v.seniorName}</td><td>${v.volunteerName}</td><td>${v.activityName}</td><td>${v.scheduledAt}</td><td>${v.status}</td></tr></c:forEach></tbody></table></div></div>
<div class="card"><h2>Safety reports</h2><div class="table-wrap"><table><thead><tr><th>Senior</th><th>Volunteer</th><th>Description</th><th>Status</th><th>Action</th></tr></thead><tbody><c:forEach var="rp" items="${reports}"><tr><td>${rp.seniorName}</td><td>${rp.volunteerName}</td><td>${rp.description}</td><td>${rp.status}</td><td><form method="post" action="<%=ctx%>/admin/monitoring" class="small-form"><input type="hidden" name="id" value="${rp.id}"><select name="status"><option>PENDING</option><option>REVIEWING</option><option>CLOSED</option></select><input name="adminNotes" placeholder="Admin notes"><button>Update</button></form></td></tr></c:forEach></tbody></table></div></div>
<div class="card"><h2>Contact enquiries</h2><div class="table-wrap"><table><thead><tr><th>Name</th><th>Email</th><th>Message</th><th>Status</th></tr></thead><tbody><c:forEach var="e" items="${enquiries}"><tr><td>${e.name}</td><td>${e.email}</td><td>${e.message}</td><td>${e.status}</td></tr></c:forEach></tbody></table></div></div>
<%@ include file="../partials/footer.jspf" %>
